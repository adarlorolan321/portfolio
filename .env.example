# Base URL for the application (trailing slash required)
# Production:
VITE_BASE_URL=https://portfolio-rolan.netlify.app/

# Local Vite only (assets only — API will not work):
# VITE_BASE_URL=http://localhost:5173/

# Local with Netlify Database + API (use npm run dev:netlify → http://localhost:8888):
# VITE_BASE_URL=http://localhost:8888/

# Netlify Database — set automatically by `netlify dev` and Netlify deploy.
# Do not commit real values. Run `netlify database migrations apply` for local schema.
# NETLIFY_DATABASE_URL=
